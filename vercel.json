{
  "version": 2,
  "name": "rival-design",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/admin/[...endpoint].js"
    },
    {
      "src": "/api/admin/content/(.*)",
      "dest": "/api/admin/content/[action].js"
    },
    {
      "src": "/admin(.*)",
      "dest": "/admin/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "VITE_SUPABASE_URL": "https://tlzxcghfvgazkzaoawtj.supabase.co"
  },
  "build": {
    "env": {
      "SUPABASE_SERVICE_KEY": "@supabase_service_key"
    }
  }
}
